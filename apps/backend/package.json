{
  "name": "@chatai/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @chatai/contracts build && tsc -p tsconfig.json",
    "db:codegen": "node scripts/codegen-db-schema.mjs",
    "dev": "pnpm --filter @chatai/contracts build && NODE_ENV=development tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @chatai/contracts build && tsc --noEmit"
  },
  "dependencies": {
    "@chatai/contracts": "workspace:*",
    "@fastify/env": "^5.0.3",
    "@fastify/jwt": "^10.0.0",
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.8",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "dotenv": "^17.4.2",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
