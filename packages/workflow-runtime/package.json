{
  "name": "@chatai/workflow-runtime",
  "private": true,
  "license": "UNLICENSED",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @chatai/contracts build && pnpm --filter @chatai/workflow-engine build && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @chatai/contracts build && pnpm --filter @chatai/workflow-engine build && tsc --noEmit"
  },
  "dependencies": {
    "@chatai/contracts": "workspace:*",
    "@chatai/workflow-engine": "workspace:*",
    "@sinclair/typebox": "^0.34.41",
    "kysely": "^0.29.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
