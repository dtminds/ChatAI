VITE_API_BASE_URL=/api
VITE_DEV_SERVER_HOST=chat-dev.bokr.com.cn
VITE_DEV_SERVER_PORT=8086
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001
VITE_DEV_API_PROXY_SECURE=true
VITE_WECHAT_EMOJI_BASE_URL=

# 可选：配置后侧栏自定义 iframe 会在 URL 上拼接 rd、fsw、ts（均为 Base64 密文，AES/CBC/PKCS5Padding，与 Java 解密一致）
# rd 明文为 thirdUserId 字符串本身；fsw 明文为 thirdExternalUserId 字符串本身；ts 明文为 Unix 秒十进制字符串（与 Java 及部分历史约定对齐；也可用 JSON 明文，须与后端一致）
# 密钥、IV 须与 Java 端一致；密钥截取规则见 apps/web/src/lib/tuse-crypto.ts
# VITE_TUSE_AES_KEY=
# VITE_TUSE_AES_IV=

NODE_ENV=development
PORT=3001
JAVA_INTERNAL_API_BASE_URL=
JAVA_INTERNAL_API_TOKEN=
JAVA_INTERNAL_API_TIMEOUT_MS=8000
JWT_AUDIENCE=chatai-web
AUTH_COOKIE_SECURE=false
JWT_ISSUER=chatai-server
LOG_LEVEL=info
REDIS_ENABLED=false
