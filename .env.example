VITE_API_BASE_URL=/api
VITE_DEV_SERVER_HOST=chat-dev.bokr.com.cn
VITE_DEV_SERVER_PORT=8086
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001
VITE_DEV_API_PROXY_SECURE=true
# COS 上传后公网访问域名，需与后端 PLAYABLE_MEDIA_HOST 保持一致
VITE_PLAYABLE_MEDIA_HOST=b5.bokr.com.cn
# 本地 COS 直传走 Vite /__cos 代理，避免浏览器跨域；生产构建自动关闭
# VITE_COS_DEV_PROXY=false
VITE_WECHAT_EMOJI_BASE_URL=
# 浏览器 OCR CDN 默认值见 apps/web/src/pages/chat/lib/ocr-runtime-manifest.ts
# 正常发 web 不必配置；仅预发或临时切换 CDN 时取消注释
# VITE_OCR_PADDLE_MODULE_URL=
# VITE_OCR_PADDLE_WORKER_URL=
# VITE_OCR_PADDLE_MODEL_BASE_URL=
# Enable temporary Workflow account/tag fixture options only in dev and test01 builds.
VITE_WORKFLOW_FIXTURES_ENABLED=false
# VITE_OCR_ORT_WASM_BASE_URL=

# 侧栏 iframe 参数（rd/fsw/ts/mid）由后端按 MySQL `xy_wap_embed_user_relation` 签发，见 POST /api/server/sidebar-iframe-params

NODE_ENV=development
PORT=3001
JAVA_INTERNAL_API_BASE_URL=
JAVA_INTERNAL_API_TOKEN=
JAVA_INTERNAL_API_TIMEOUT_MS=8000
JAVA_INTERNAL_API_AGENT_TEST_TIMEOUT_MS=60000
JAVA_INTERNAL_API_STREAM_IDLE_TIMEOUT_MS=60000
PLAYABLE_MEDIA_HOST=b5.bokr.com.cn
JWT_AUDIENCE=chatai-web
AUTH_COOKIE_SECURE=false
JWT_ISSUER=chatai-server
LOG_LEVEL=info
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=chatai:
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_COMMAND_TIMEOUT_MS=500
INSIGHTS_WORKER_ENABLED=false
INSIGHTS_WORKER_MODEL_ENABLED=false
INSIGHTS_WORKER_INTERVAL_MS=3000
INSIGHTS_WORKER_BATCH_SIZE=200
INSIGHTS_WORKER_START_LOOKBACK_DAYS=3
INSIGHTS_WORKER_UID_ALLOWLIST=
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_ARK_MODEL=
VOLCENGINE_ARK_LITE_MODEL=
VOLCENGINE_ARK_LITE_MAX_TOKENS=
# Required when NODE_ENV is production or test. Local development may leave it empty.
DATABASE_URL=
# Required in production. Local development and test may leave it empty.
